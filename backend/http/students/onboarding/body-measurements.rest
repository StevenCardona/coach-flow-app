@baseUrl = http://localhost:5500/api
@token = {{login.response.body.data.token}}
@measurementId = <id_de_la_medida>

### Login student
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "alumno@ejemplo.com",
  "password": "newpassword123"
}

### Register body measurement
POST {{baseUrl}}/me/onboarding/body-measurements
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "weightKg": 72.5,
  "heightCm": 175,
  "measuredAt": "2026-06-29",
  "chestCm": 98,
  "waistCm": 82,
  "hipCm": 95,
  "armCm": 32,
  "bicepCm": 35
}

### Update measurement
PUT {{baseUrl}}/me/onboarding/body-measurements/{{measurementId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "weightKg": 71.8,
  "waistCm": 80
}

### List measurements
GET {{baseUrl}}/me/onboarding/body-measurements
Authorization: Bearer {{token}}
