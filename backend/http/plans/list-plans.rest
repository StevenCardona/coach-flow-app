@baseUrl = http://localhost:5500/api
@token = {{login.response.body.data.token}}

### Login coach
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "coach@ejemplo.com",
  "password": "password123"
}

### List plans (paginated)
GET {{baseUrl}}/plans?page=1&pageSize=10&sortBy=name&sortOrder=asc
Authorization: Bearer {{token}}

### List active plans only
GET {{baseUrl}}/plans?page=1&pageSize=10&isActive=true
Authorization: Bearer {{token}}

### Search plans
GET {{baseUrl}}/plans?page=1&pageSize=10&search=premium
Authorization: Bearer {{token}}

### Get plan by ID
@planId = <uuid_del_plan>
GET {{baseUrl}}/plans/{{planId}}
Authorization: Bearer {{token}}
